# =============================================================================
# BACKEND .dockerignore
# Build context: ./backend (từ docker-compose)
# =============================================================================

# ─── Node modules (sẽ được cài lại bởi RUN npm install trong Dockerfile) ─────
node_modules

# ─── Build outputs (sẽ được tạo bởi RUN npm run build) ───────────────────────
dist

# ─── Prisma generated client (sẽ được tạo bởi RUN npx prisma generate) ───────
generated

# ─── Environment secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Test files ──────────────────────────────────────────────────────────────
test/
coverage/
*.spec.ts
*.e2e-spec.ts

# ─── TypeScript cache ────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── OS / IDE ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ─── Git ─────────────────────────────────────────────────────────────────────
.git
.gitignore

# ─── Scripts phụ / docs ──────────────────────────────────────────────────────
README.md
fix.js
